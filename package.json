{
  "name": "halaqa-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm --workspace apps/mobile run start",
    "studio": "npm --workspace apps/studio run dev",
    "build:studio": "npm --workspace apps/studio run build"
  }
}

